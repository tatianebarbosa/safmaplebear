# Variáveis de Ambiente para o Projeto MapleBear SAF

# ------------------------------------------------------------------
# Configuração do Frontend (Vite)
# ------------------------------------------------------------------

# Prefixo para variáveis de ambiente expostas ao código do cliente
# Todas as variáveis que começam com VITE_ serão expostas
# Exemplo: VITE_API_BASE_URL=http://localhost:7071

# URL base da API do backend (Azure Functions)
# Em desenvolvimento, o proxy do vite.config.ts cuida disso, mas é bom ter para builds
# VITE_API_BASE_URL=http://localhost:7071

# VITE_CORE_VIEW_RESTRICTION controls restricted menu/route view for non-admin users.
# Values: production (default), staging/preview, all/true, false/0.
VITE_CORE_VIEW_RESTRICTION=production
# VITE_ENABLE_ONLY_CANVA=true to force canva-only for non-admin in any environment.
# If false, restrictions come from VITE_CORE_VIEW_RESTRICTION.
VITE_ENABLE_ONLY_CANVA=false

# Optional explicit deploy env for access policy.
# Use production, staging, dev, etc. when needed.
VITE_DEPLOY_ENV=production


# ------------------------------------------------------------------
# Login tempor?rio do painel (simula??o no frontend)
# Configure conforme necess?rio para liberar o acesso.
# ------------------------------------------------------------------
VITE_ADMIN_EMAIL=temp_admin@mbcentral.com.br
VITE_ADMIN_PASSWORD=saf123
VITE_ADMIN_NAME=Admin Temporario
VITE_ADMIN_ROLE=admin
# Defina como "true" se precisar bloquear o acesso nas segundas-feiras
# VITE_ENFORCE_MONDAY_LOGOUT=false

# Limite padrão de licenças por escola (ajustável futuramente)
VITE_MAX_LICENSES_PER_SCHOOL=2

# Chave de API para serviços externos (se houver)
# VITE_EXTERNAL_API_KEY=

# ------------------------------------------------------------------
# Configuração do Backend (Azure Functions)
# ------------------------------------------------------------------

# As variáveis de ambiente do backend devem ser configuradas no arquivo
# api/local.settings.json (para desenvolvimento local) ou no Azure (para produção)

# Chave de conexão com o Azure Storage (para blobs, filas, etc.)
# AzureWebJobsStorage=UseDevelopmentStorage=true

# Chave secreta para JWT (JSON Web Token)
# JWT_SECRET=sua_chave_secreta_aqui

# Outras configurações específicas do backend...
# Exemplo: SCHOOL_DATA_BLOB_CONTAINER=

# ------------------------------------------------------------------
# Configurações do Canva
# ------------------------------------------------------------------

# Esta versão utiliza apenas ingestão manual de dados (upload de arquivos).
# As variáveis de credenciais de login do Canva foram removidas do projeto.
